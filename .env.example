# --- Redis (broker + job store + result cache) ---
REDIS_URL=redis://localhost:6379/0
JOB_TTL_SECONDS=7200
DATABASE_URL=postgresql://devvoice:devvoice@localhost:5432/devvoice

# --- Model selection ---
# MODEL_PROVIDER: ollama (default) | groq | openai | anthropic
MODEL_PROVIDER=ollama
MODEL_TEMPERATURE=0.4
# MODEL_NAME applies to groq/openai/anthropic (e.g. claude-sonnet-4-6)
# MODEL_NAME=

# Ollama (default, matches the tutorial .env)
OLLAMA_MODEL=minimax-m2.5:cloud
OLLAMA_BASE_URL=http://localhost:11434

# Provider keys (only the one matching MODEL_PROVIDER is required)
ANTHROPIC_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=

# Tavily — optional, used by the reviewer's fact_check tool
TAVILY_API_KEY=

# Context engineering
SUMMARIZE_TRIGGER_TOKENS=12000
SUMMARIZE_KEEP_MESSAGES=20
